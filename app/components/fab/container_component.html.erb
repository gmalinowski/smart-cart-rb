<div class="fab bottom-20 right-6">
  <!-- a focusable div with tabindex is necessary to work on all browsers. role="button" is necessary for accessibility -->
  <div tabindex="0" role="button" class="btn btn-lg shadow-xl btn-circle btn-secondary">
    <%= helpers.heroicon "plus", class: "size-6" %>
  </div>

  <!-- buttons that show up when FAB is open -->
  <% items.each do |item| %>
    <%= render item %>
  <% end %>
</div>
