<hr class="border-t border-neutral-content mt-8 mx-8">

<h2 class="text-gray-400 text-center m-4">Sent requests</h2>

<ul class="list rounded-box gap-1 p-4">
  <% sent_requests.each do |sent_request| %>
    <li class="grid grid-cols-12 p-4 bg-warning/10 rounded-box shadow-sm ">
      <div class="col-span-12 md:col-span-11 flex flex-col gap-4">
        <div class="flex gap-4 items-center">
          <div>
            <img class="size-10 rounded-box" src="https://img.daisyui.com/images/profile/demo/3@94.webp"/>
          </div>
          <div>
            <div><%= sent_request.friend.email %></div>
            <div class="text-xs uppercase font-semibold opacity-60"></div>
          </div>
        </div>
        <%= button_to t('friendships.actions.cancel'), friendship_path(sent_request), method: :delete, class: "btn btn-xs btn-warning w-full" %>
      </div>
    </li>
  <% end %>
</ul>
