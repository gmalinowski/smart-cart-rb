
<%= turbo_stream.append "modals" do %>
  <%= render Modal::ModalComponent.new(id: "invitation_link_modal", title: "Share this link with friend") do |modal| %>
    <% modal.with_body do %>
      <input type="text" value="<%= @invitation_link.token %>" readonly class="input" />
    <% end %>

  <% end %>
<% end %>