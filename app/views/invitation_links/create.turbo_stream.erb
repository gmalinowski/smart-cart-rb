
<%= turbo_stream.append "modals" do %>
  <div data-controller="clipboard" data-clipboard-success-content-value="Copied!">
  <%= render Modal::ModalComponent.new(id: "invitation_link_modal", title: "Share this link with friend") do |modal| %>
    <% modal.with_body do %>
        <input type="text" class="input input-success" value="<%= accept_invitation_link_url(@invitation_link.token) %>" data-clipboard-target="source" />

        <button type="button" class="btn btn-success btn-sm" data-action="clipboard#copy" data-clipboard-target="button">Copy to clipboard</button>
    <% end %>

  <% end %>
  </div>
<% end %>