
<div class="flex flex-col items-center justify-center gap-4">
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <div class="flex flex-col w-full gap-3">
    <legend class="fieldset-legend">Reset password</legend>

    <%= f.label :email, class: "floating-label" do %>
      <span>Your email</span>
      <%= f.email_field :email, placeholder: "Your Email", autofocus: true, autocomplete: "email", class: "input" %>
      <%= render "devise/shared/field_error", input_name: :email %>
    <% end %>

  <div class="actions">
    <%= f.submit "Send me password reset instructions", class: "btn btn-warning mt-4" %>
  </div>
    </div>
<% end %>

<%= render "devise/shared/links" %>
</div>