
<li
  data-controller="shopping-list-item"
  data-shopping-list-item-shopping-list-outlet="#shopping_list_items"
  data-shopping-list-item-toggle-url-value="<%= toggle_shopping_list_shopping_list_item_path(shopping_list_item.shopping_list, shopping_list_item) %>"
  data-shopping-list-item-update-url-value="<%= shopping_list_shopping_list_item_path(shopping_list_item.shopping_list, shopping_list_item) %>"
  data-shopping-list-item-id-value="<%= shopping_list_item.id %>"
  data-shopping-list-item-checked-value="<%= shopping_list_item.checked %>"
  data-action="click->shopping-list-item#toggle"
  id="<%= dom_id(shopping_list_item) %>"
  tabindex="0"
  class="shopping-list-item grid grid-cols-12 justify-between items-center rounded-xl shadow-sm p-4 py-2 bg-primary text-primary-content font-medium active:bg-primary/80"
>
  <div id="item-title"
       data-action="click->shopping-list-item#edit:stop"
       class="col-span-6">
    <h1
      data-shopping-list-item-target="itemName"
      data-action="blur->shopping-list-item#save:stop"
      id="item-title-content" contenteditable="true"
      class="focus:px-2 focus:py-1 focus:outline-accent pr-2 border-b border-primary-content/30">
      <%= shopping_list_item.name %>
    </h1>
  </div>
  <div data-action="click->shopping-list-item#stopPropagation:stop"
       class="dropdown dropdown-left dropdown-center -col-end-1">
    <div tabindex="-1" role="button" aria-label="lists item options" class="m-1 active:bg-primary/20 focus:bg-primary/20 hover:bg-primary/20 btn btn-circle btn-ghost">
      <%= heroicon "ellipsis-vertical", class: "size-4" %>
    </div>
    <ul tabindex="-1" class="dropdown-content menu bg-base-100 rounded-box z-1 w-52 p-2 shadow-sm">
      <li class="">
        <%= form_with model: [shopping_list_item.shopping_list, shopping_list_item], method: :delete, class: "inline-block flex gap-1" do |f| %>
          <%= f.button type: :submit, class: "btn btn-xs btn-error" do %>
            <%= heroicon "trash", class: "size-4" %>
            Delete
          <% end %>
        <% end %>
      </li>
    </ul>
  </div>
</li>
